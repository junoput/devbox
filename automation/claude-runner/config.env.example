# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Proxmox
PROXMOX_HOST=192.168.88.21
PROXMOX_SSH_KEY=~/.ssh/camenzindt_macbook

# Source VM to clone from
SOURCE_LXC=108
SOURCE_SNAPSHOT=cluborbit-dev-ready

# Script to run on the VM after clone to pull latest code.
# Runs as root inside the new VM. Leave empty to skip.
POST_CLONE_SCRIPT=/opt/devbox/apps/cluborbit.sh

# Secrets directory to copy from the source LXC into the new VM.
# Entire directory is mirrored. Leave empty to skip.
SECRETS_SOURCE_DIR=/root/.secrets

# Ephemeral VM allocation
LXC_ID_RANGE_START=200
LXC_ID_RANGE_END=299
LXC_BRIDGE=vmbr1
LXC_IP_PREFIX=192.168.66
LXC_IP_RANGE_START=100
LXC_IP_RANGE_END=199
LXC_GATEWAY=192.168.66.1
LXC_SSH_KEY=~/.ssh/camenzindt_macbook
HOSTNAME_PREFIX=claude-dev

# Runner defaults
WORKSPACE=/opt/dev/workspace
IDLE_TIMEOUT=120

# Claude model + effort (both optional — leave empty for Haiku auto-selection per task)
# Model:  haiku | sonnet | opus  (or full ID e.g. claude-sonnet-4-6)
# Effort: low | medium | high | xhigh
CLAUDE_MODEL=
CLAUDE_EFFORT=
MAX_TURNS=50

# Set true to skip Haiku preflight (saves ~1s + a few cents per launch)
NO_PREFLIGHT=false
# Set true to skip Haiku diff review before PR creation
NO_REVIEW=false

# Anthropic API key — injected into the Claude session for auth recovery.
# Can also be stored in a secrets file sourced at run time.
ANTHROPIC_API_KEY=
ANTHROPIC_SECRETS_FILE=/root/.secrets/anthropic.env
